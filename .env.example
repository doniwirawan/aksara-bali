# Supabase Configuration
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Configuration
# Set this to your admin user's email (must be registered in Supabase Auth)
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# Unsplash (optional - for Bali photo picker in admin)
# Get from: unsplash.com/developers → your app → Access Key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# Site URL (used for SEO canonical URLs)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
